APP_NAME=MajSpirit API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=appuser
MYSQL_PASSWORD=change_to_strong_password
MYSQL_DB=majspirit
MYSQL_ROOT_PASSWORD=change_to_strong_root_password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_to_strong_redis_password

JWT_SECRET_KEY=change_to_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

RATE_LIMIT_PER_MINUTE=120
WS_HEARTBEAT_TIMEOUT_SECONDS=60